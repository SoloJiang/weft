      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg1RTgyRUNGQ0U4ODkxMzYKUldRMmtZak96eTdvaFZKejlZOGRnVk9iQ2M1RlZDNDRkY25nMmdPNkF5NDZIWWs2L1hxL2NWZzMK",
